importar jpk

janela = jpk_janela("aplicação", 600, 600)
jpk_fundo(janela, 255, 0, 0)
botao_1 = jpk_botao(janela, "clique aqui", 300, 300, 100, 50)
botao_2 = jpk_botao(janela, "fechar", 300, 400, 100, 50)
entra = jpk_input(janela, "digite algo", 300, 200, 100, 50)

enquanto verdadeiro:
    foi = jpk_input_valor(entra)
    se jpk_clicado(botao_1) == 1:
        saida("clicou")
        saida(foi)
    se jpk_clicado(botao_2) == 1:
        saida("saindo")
        parar
    jpk_exibir(janela)