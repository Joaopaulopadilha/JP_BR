importar python

python_iniciar()

python_executar("import tkinter as tk")
python_executar("janela = tk.Tk()")
python_executar("janela.title('Ola do JPLang')")
python_executar("janela.geometry('400x300')")
python_executar("janela.configure(bg='#1a1a2e')")
python_executar("label = tk.Label(janela, text='Ola Mundo!', fg='white', bg='#1a1a2e', font=('Arial', 24))")
python_executar("label.pack(expand=True)")
python_executar("janela.mainloop()")

python_finalizar()
saida("Fim!")