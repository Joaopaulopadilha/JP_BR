importar svs

porta = svs_criar(8080)
ip = svs_meu_ip()
saidal("servidor rodando em:")
saida_amarelo(ip + ":" + porta)

enquanto verdadeiro:
    req = svs_aguardar(porta)
    caminho = svs_caminho(req)
    
    se caminho == "/":
        svs_arquivo(req, "utilitarios_javascript\interface_ollama.html")
    senao:
        svs_responder(req, 404, "Não encontrado")