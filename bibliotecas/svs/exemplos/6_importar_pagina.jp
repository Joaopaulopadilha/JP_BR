importar "bibliotecas\svs\exemplos\6_pagina_importada.jp"
importar svs

porta = svs_criar(8080)
ip = svs_meu_ip()
saida("Servidor em: {ip}:{porta}")


enquanto verdadeiro:
    req = svs_aguardar(porta)
    caminho = svs_caminho(req)
    
    se caminho == "/":
        svs_responder_html(req, 200, pagina)
    senao:
        svs_responder(req, 404, "Página não encontrada")